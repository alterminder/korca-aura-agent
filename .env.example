# Copy this file to .env for local development.
# Keep real credentials in .env or your secret manager; do not commit them.

# Gemini document processing, generation, and embeddings
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_GENERATION_MODEL=gemini-2.5-flash

# Neo4j Aura
NEO4J_URI_AURA=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER_AURA=neo4j
NEO4J_PASS_AURA=
NEO4J_DATABASE_AURA=neo4j

# Aura agent endpoints
AURA_CLIENT_ID=
AURA_CLIENT_SECRET=
AURA_AGENT_ENDPOINT=https://api.neo4j.io/v2beta1/organizations/<org-id>/projects/<project-id>/agents/<agent-id>/invoke

# Teamwork Desk
TEAMWORK_API_KEY=
TEAMWORK_SUBDOMAIN=<subdomain>.teamwork.com
TEAMWORK_FALLBACK_AGENT_EMAIL=
TEAMWORK_STAGING_EXPERT_NAME=
TEAMWORK_STAGING_EXPERT_EMAIL=
TEAMWORK_SUBJECT_BLOCKLIST=
TEAMWORK_PERSONAL_DOMAINS=gmail.com,yahoo.com,hotmail.com,outlook.com,icloud.com,me.com,protonmail.com

# App (optional)
KORCA_ENV=development
KORCA_DEBUG=true
# Docker Compose users normally set only KORCA_AUTH_PASSWORD.
# Leave KORCA_AUTH_COOKIE_SECRET_FILE empty unless overriding the Compose default.
KORCA_AUTH_PASSWORD=
KORCA_AUTH_COOKIE_SECRET=
KORCA_AUTH_COOKIE_SECRET_FILE=
KORCA_AUTH_COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
UPLOAD_MAX_SIZE_MB=50
REDIS_URL=redis://localhost:6379
PDF_STORAGE_PATH=/data/pdfs
TEMP_UPLOAD_PATH=/tmp/korca-uploads
